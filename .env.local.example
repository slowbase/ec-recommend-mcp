# 楽天ウェブサービス (https://webservice.rakuten.co.jp/app/list)
# 2026-04-01版APIでは Application ID と Access Key の両方が必須。
RAKUTEN_APP_ID=
RAKUTEN_ACCESS_KEY=
# 楽天に登録した Application URL（Origin/Refererヘッダーとして送信する）
RAKUTEN_APP_URL=

# 楽天アフィリエイトID
RAKUTEN_AFFILIATE_ID=

# (任意) SSEトランスポートを有効化する場合のみ必要。
# VercelではUpstash等のRedisを用意し、URLを設定する。
# REDIS_URL=
